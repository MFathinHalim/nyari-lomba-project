{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user document was created"
        },
        "savedCompetitions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of saved competition IDs"
        }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    }
  }
}
